# ============================================
# Boho Cafe & Lounge — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values

# Resend API key (get from https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email where reservation/contact submissions are sent
CONTACT_RECEIVER_EMAIL=hs142636@gmail.com

# Google Maps embed URL (optional, has fallback)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=...

# Supabase (get from https://supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel password (used to access /admin dashboard)
ADMIN_SECRET=your-secure-admin-password

# Site URL (used for email action links)
# In production, set this to your live domain e.g. https://bohocafe.in
NEXT_PUBLIC_SITE_URL=http://localhost:3000
